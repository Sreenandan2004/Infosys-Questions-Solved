   "source": [
    "# Tree Rooted Subtree Intersection\n",
    "## Problem Description\n",
    "Given a tree. `beauty(U, V)` is the number of nodes in the intersection of `subtree(U)` when rooted at $A$, and `subtree(V)` when rooted at $B$.\n",
    "Find the sum of answers to $Q$ online queries modulo $10^9+7$.\n",
    "\n",
    "## Example Test Case\n",
    "Input: $N=2, A=1, B=2, P=[0, 1], Q=[[1, 2]]$\n",
    "Output: 0\n",
    "Explanation: Subtree of 2 rooted at 1 is $\{2\}$, subtree of 1 rooted at 2 is $\{1\}$. Intersection is empty."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def solve_subtree_intersection(n, A, B, parents, queries):\n",
    "    adj = [[] for _ in range(n + 1)]\n",
    "    root = 1\n",
    "    for i, p in enumerate(parents, 1):\n",
    "        if p == 0: root = i\n",
    "        else:\n",
    "            adj[p].append(i)\n",
    "            adj[i].append(p)\n",
    "            \n",
    "    LOGN = 18\n",
    "    up = [[0] * (n + 1) for _ in range(LOGN)]\n",
    "    depth = [0] * (n + 1)\n",
    "    tin = [0] * (n + 1)\n",
    "    tout = [0] * (n + 1)\n",
    "    timer = 0\n",
    "    \n",
    "    def dfs(u, p, d):\n",
    "        nonlocal timer\n",
    "        timer += 1\n",
    "        tin[u] = timer\n",
    "        depth[u] = d\n",
    "        up[0][u] = p\n",
    "        for i in range(1, LOGN):\n",
    "            up[i][u] = up[i-1][up[i-1][u]]\n",
    "        for v in adj[u]:\n",
    "            if v != p: dfs(v, u, d + 1)\n",
    "        tout[u] = timer\n",
    "        \n",
    "    dfs(root, 0, 0)\n",
    "    \n",
    "    def is_ancestor(u, v):\n",
    "        return tin[u] <= tin[v] <= tout[u]\n",
    "        \n",
    "    def get_child_ancestor(u, v):\n",
    "        curr = v\n",
    "        for i in range(LOGN - 1, -1, -1):\n",
    "            parent = up[i][curr]\n",
    "            if parent != 0 and depth[parent] > depth[u]:\n",
    "                curr = parent\n",
    "        return curr\n",
    "\n",
    "    def get_intervals(u, r):\n",
    "        if u == r: return [[1, n]]\n",
    "        if not is_ancestor(u, r): return [[tin[u], tout[u]]]\n",
    "        c = get_child_ancestor(u, r)\n",
    "        res = []\n",
    "        if tin[c] > 1: res.append([1, tin[c] - 1])\n",
    "        if tout[c] < n: res.append([tout[c] + 1, n])\n",
    "        return res\n",
    "\n",
    "    ans_sum = 0\n",
    "    last_ans = 0\n",
    "    MOD = 10**9 + 7\n",
    "    \n",
    "    for u_raw, v_raw in queries:\n",
    "        u = (u_raw + last_ans) % n + 1\n",
    "        v = (v_raw + last_ans) % n + 1\n",
    "        int_A = get_intervals(u, A)\n",
    "        int_B = get_intervals(v, B)\n",
    "        curr_ans = 0\n",
    "        for l1, r1 in int_A:\n",
    "            for l2, r2 in int_B:\n",
    "                l_max = max(l1, l2)\n",
    "                r_min = min(r1, r2)\n",
    "                if l_max <= r_min: curr_ans += r_min - l_max + 1\n",
    "        ans_sum = (ans_sum + curr_ans) % MOD\n",
    "        last_ans = curr_ans\n",
    "    return ans_sum\n",
    "\n",
    "print(solve_subtree_intersection(2, 1, 2, [0, 1], [(1, 2)]))"
   ]
  }
